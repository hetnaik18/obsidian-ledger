{
  "name": "obsidian-ledger-backend",
  "version": "1.0.0",
  "description": "Backend for The Obsidian Ledger - AI-powered documentation RPG",
  "main": "dist/server.js",
  "scripts": {
    "predev": "npx kill-port 3001 || true",
    "dev": "nodemon --exec ts-node src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@google/generative-ai": "^0.1.3",
    "@obsidian-ledger/shared": "*",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "openai": "^6.25.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "kill-port": "^2.0.1",
    "nodemon": "^3.0.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.2"
  }
}
