{
  "manifest_version": 3,
  "name": "Blackbox AI Agent",
  "version": "4.4",
  "description": "AI Agent for Blackbox",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "injected.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
